# ═══ SECRETS — never commit ════════════════════════════════
.env
.env.*
!.env.example
config/settings.yaml

# ═══ Local database (stays on your machine) ════════════════
store/*.sqlite
store/*.sqlite3
store/*.db
store/*.sqlite-wal
store/*.sqlite-shm
store/*.sqlite-journal
store/ohlcv/
store/cache/
store/evidence/**/*
!store/.gitkeep
!store/evidence/.gitkeep

# ═══ Cached market data ════════════════════════════════════
data/
*.csv

# ═══ Claude drop zone (archive only — not source) ═════════
others/
*.zip
cassandra_dashboard_ui_mockup.html
newspaper.html

# ═══ Python ════════════════════════════════════════════════
__pycache__/
*.py[cod]
*.pyo
.eggs/
*.egg-info/
build/
dist/

# ═══ Virtual environments ══════════════════════════════════
.venv/
venv/
env/

# ═══ Reports output (generated, not source) ════════════════
reports/*
!reports/.gitkeep
*.md.out

# ═══ Tooling ═══════════════════════════════════════════════
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

