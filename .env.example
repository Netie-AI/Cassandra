# CASSANDRA — copy to .env and fill in keys. See docs/DATA_SOURCES.md + docs/DATA_ROUTING.md

# ── Gemini (daily report text — ai.google.dev free tier) ──────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Anthropic (original BUILD spec — optional)
ANTHROPIC_API_KEY=
# OpenRouter — multi-model gateway (recommended if no Anthropic)
OPENROUTER_API_KEY=
# Groq — fast inference fallback
GROQ_API_KEY=
GROQ_API_KEY_SISWA=
# SEA-LION — Malaysia/SEA optimised (optional)
SEA_LION_API_KEY=
SEA_LION_API_KEY_SISWA=

# ── CORE macro (free) ─────────────────────────────────────────────
FRED_API_KEY=
ALPHAVANTAGE_API_KEY=

# ── US market data ────────────────────────────────────────────────
# Massive = Polygon.io rebrand (same key, same api.polygon.io)
POLYGON_API_KEY=
MASSIVE_API_KEY=
MARKETSTACK_API_KEY=
EODHD_API_KEY=
FINNHUB_API_KEY=
FINNHUB_WEBHOOK_SECRET=
TWELVEDATA_API_KEY=
# yfinance — no key needed (pip install yfinance)

# ── Crypto sentiment ──────────────────────────────────────────────
COINGECKO_API_KEY=
GLASSNODE_API_KEY=

# ── Options flow / smart money (paid, optional) ───────────────────
UW_API_KEY=
FMP_API_KEY=
QUIVER_API_KEY=
ORATS_TOKEN=

# Alpaca paper trading (free market data) — https://github.com/alpacahq/alpaca-py
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
TRADIER_SANDBOX_TOKEN=
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111

# ── Web search (news digestor) ────────────────────────────────────
TAVILY_API_KEY=
SERPER_API_KEY=

# ── Cloudflare publish (Phase 3 — local pipeline → public dashboard) ──
CF_KV_ENDPOINT=
CF_KV_SECRET=

# ── API auth (set before public deploy; unset = open in local dev) ──
PIPELINE_KEY=
DEV_GEO_COUNTRY=MY
