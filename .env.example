# CASSANDRA — copy to .env and fill in keys. See docs/DATA_SOURCES.md + docs/DATA_ROUTING.md

# ── Gemini (daily report text — ai.google.dev free tier) ──────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Anthropic (original BUILD spec — optional)
ANTHROPIC_API_KEY=
# OpenRouter — multi-model gateway (recommended if no Anthropic)
OPENROUTER_API_KEY=
# Groq — fast inference fallback
GROQ_API_KEY=
GROQ_API_KEY_SISWA=
# SEA-LION — Malaysia/SEA optimised (optional)
SEA_LION_API_KEY=
SEA_LION_API_KEY_SISWA=

# ── CORE macro (free) ─────────────────────────────────────────────
FRED_API_KEY=
ALPHAVANTAGE_API_KEY=

# ── US market data ────────────────────────────────────────────────
# Massive = Polygon.io rebrand (same key, same api.polygon.io)
POLYGON_API_KEY=
MASSIVE_API_KEY=
MARKETSTACK_API_KEY=
EODHD_API_KEY=
FINNHUB_API_KEY=
FINNHUB_WEBHOOK_SECRET=
TWELVEDATA_API_KEY=
# yfinance — no key needed (pip install yfinance)

# ── Crypto sentiment ──────────────────────────────────────────────
COINGECKO_API_KEY=
GLASSNODE_API_KEY=

# ── Options flow / smart money (paid, optional) ───────────────────
UW_API_KEY=
FMP_API_KEY=
QUIVER_API_KEY=
ORATS_TOKEN=

# Alpaca paper trading (free market data) — https://github.com/alpacahq/alpaca-py
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
TRADIER_SANDBOX_TOKEN=
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111

# ── Web search (news digestor) ────────────────────────────────────
TAVILY_API_KEY=
SERPER_API_KEY=

# ── Cloudflare publish (Phase 3 — local pipeline → public dashboard) ──
CF_KV_ENDPOINT=
CF_KV_SECRET=

# ── API auth (set before public deploy; unset = open in local dev) ──
PIPELINE_KEY=
DEV_GEO_COUNTRY=MY

# ── Supabase (accounts, watchlists, send log — see config/supabase.schema.sql) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Newsletter (Resend preferred — see docs/OPS_PLUG_IN.md) ───────
RESEND_API_KEY=
RESEND_FROM_DIGEST=cassandra@mail.netie.ai
RESEND_FROM_AUTH=no-reply@mail.netie.ai
RESEND_REPLY_TO=hello@netie.ai
RESEND_AUDIENCE_ID=
CONTACT_TO=desk@netie.ai
NEWSLETTER_FROM=Cassandra Desk <cassandra@mail.netie.ai>
NEWSLETTER_REPLY_TO=hello@netie.ai
# cPanel / SMTP fallback (leave blank if using Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# ── Cloudflare deploy (scripts/build-cf.ps1 patches _redirects) ───
CF_WORKER_URL=

# ── Newsletter opt-in mode (false = auto-confirm at signup) ─────
DIGEST_DOUBLE_OPTIN=false

# ── Office schedule hints (Task Scheduler / manual) ───────────────
OPS_TIMEZONE=Asia/Kuala_Lumpur
OPS_OFFICE_TIME=09:00
OPS_PRERUN_MINUTES=120

# ── Agent chat (compact context — see agents/trading_engine_compact.md) ──
OPENROUTER_AGENT_MODEL=anthropic/claude-sonnet-4-6
CONTACT_TO=desk@netie.ai

# ── Stripe (test mode for launch — swap to live keys when ready) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_REPORT=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_API=price_...
# Legacy aliases (optional)
STRIPE_PRICE_BRIEFING=
STRIPE_PRICE_AGENT=
